{
  "description": "Web app for Robot Odyssey Rewired",
  "name": "@robot-odyssey-rewired/web",
  "version": "0.16.0",
  "private": true,
  "scripts": {
    "build": "mkdir -p dist/ build/ && rm -Rf dist/* build/* && webpack --config ./webpack.config.js && echo Done.",
    "clean": "rm -Rf dist build",
    "hotserve": "webpack-serve --config ./webpack.config.js --host 0.0.0.0 --port 8000",
    "distserve": "npm run build && cd dist && python -m http.server"
  },
  "dependencies": {
    "@robot-odyssey-rewired/engine": "*",
    "base64-arraybuffer": "^0.1.5",
    "downloadjs": "^1.4.7",
    "html-dir-content": "^0.1.3",
    "idb": "^2.1.3",
    "intersection-observer": "^0.5.1",
    "jszip": "^3.10.1",
    "promise-file-reader": "^1.0.3",
    "relative-date": "^1.1.3"
  },
  "devDependencies": {
    "css-loader": "^0.28.11",
    "cssnano": "^3.10.0",
    "favicons-webpack-plugin": "0.0.9",
    "file-loader": "^1.1.11",
    "git-revision-webpack-plugin": "^3.0.6",
    "html-webpack-inline-source-plugin": "0.0.10",
    "html-webpack-plugin": "^3.2.0",
    "mini-css-extract-plugin": "^0.4.5",
    "offline-plugin": "^5.0.7",
    "optimize-css-assets-webpack-plugin": "^4.0.3",
    "remove-assets-webpack-plugin": "^1.1.0",
    "ts-loader": "^8.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "uglifyjs-webpack-plugin": "^1.3.0",
    "uglify-es": "3.3.9",
    "url-loader": "^1.1.2",
    "webfont": "^11.2.20",
    "webpack": "^4.47.0",
    "webpack-bundle-analyzer": "^2.13.1",
    "webpack-cli": "^3.1.1",
    "webpack-pwa-manifest": "^3.8.0",
    "webpack-serve": "^1.0.4"
  }
}
